{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "prolink-connect",
  "version": "0.11.0",
  "keywords": [
    "CDJ",
    "DJ",
    "cdj",
    "djm",
    "pioneer",
    "prolink-network",
    "reverse-engineer"
  ],
  "license": "MIT",
  "author": "Evan Purkhiser <evanpurkhiser@gmail.com>",
  "bin": {
    "prolink-connect": "./lib/cli.mjs"
  },
  "files": [
    "lib/"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./lib/types.d.mts",
        "default": "./lib/types.mjs"
      },
      "require": {
        "types": "./lib/types.d.cts",
        "default": "./lib/types.cjs"
      }
    }
  },
  "scripts": {
    "watch": "tsdown --watch",
    "build": "tsdown",
    "build-docs": "typedoc --out docs src/index.ts",
    "test": "vitest run",
    "lint": "oxlint src/**/*.ts tests/**/*.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "preversion": "pnpm lint; pnpm test"
  },
  "dependencies": {
    "@sentry/node": "^6.4.1",
    "@sentry/tracing": "^6.4.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "22.10.2",
    "@types/promise-retry": "^1.1.6",
    "@types/promise-timeout": "^1.3.3",
    "@types/signale": "^1.4.7",
    "async-mutex": "^0.3.0",
    "better-sqlite3": "^11.7.0",
    "ip-address": "^7.0.1",
    "js-xdr": "^1.3.0",
    "lodash-es": "^4.18.1",
    "promise-readable": "^8.0.1",
    "promise-retry": "^2.0.1",
    "promise-socket": "^8.0.0",
    "promise-timeout": "^1.3.0",
    "rekordbox-parser": "^0.1.2",
    "strict-event-emitter-types": "^2.0.0"
  },
  "devDependencies": {
    "@evanpurkhiser/oxc-config": "^0.7.0",
    "@types/stream-buffers": "^3.0.8",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "signale": "^1.4.0",
    "stream-buffers": "^3.0.3",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.10",
    "typedoc": "^0.27.4",
    "typedoc-plugin-missing-exports": "^3.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "volta": {
    "node": "24.0.0",
    "pnpm": "10.33.2"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
